# SmartParkk Environment Variables - Example Configuration
# Copy this file to backend/.env and fill in your actual values

# Server Configuration
PORT=3000

# Supabase (PostgreSQL Database & Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Web Push Notifications (VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-public-key-here
VAPID_PRIVATE_KEY=your-private-key-here

# WhatsApp Web.js (Optional - for OTP delivery)
# Leave empty if not using WhatsApp integration
PUPPETEER_EXECUTABLE_PATH=
