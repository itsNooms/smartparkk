# SmartParkk Environment Variables - Example Configuration
# Copy this file to backend/.env and fill in your actual values

# Server Configuration
PORT=3000

# Supabase (PostgreSQL Database & Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Web Push Notifications (VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-public-key-here
VAPID_PRIVATE_KEY=your-private-key-here

# Meta WhatsApp Cloud API (NO QR CODE - pure HTTP)
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# 1. Create a Meta App at developers.facebook.com
# 2. Add "WhatsApp" product to your app
# 3. Get your Phone Number ID and Permanent Access Token
WHATSAPP_TOKEN=your-meta-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
